{
  // How wsmd binds and secures its listener:
  //   "local"   - binds 127.0.0.1, plain HTTP, Bearer token required.
  //   "ssh"     - binds 127.0.0.1, reached via an SSH reverse tunnel, token required.
  //   "network" - configurable bind, HTTPS required (tls below), explicit opt-in.
  "mode": "local",

  // Bind address. Must be loopback for local/ssh; may be routable for network.
  "bind": "127.0.0.1",
  "port": 39788,

  // Bearer token, required in every mode. Prefer the $WSM_TOKEN env var, which
  // overrides this field and keeps the secret out of the config file.
  "token": "change-me",

  // Required only when mode = "network".
  "tls": { "cert": "", "key": "" },

  // Which IDE profile below to use for /open.
  "ide": "cursor",

  // Optional: let wsmd establish and maintain its OWN reverse SSH tunnel to the
  // dev box, so the dev box can reach wsmd without relying on an external SSH
  // session (e.g. Cursor Remote-SSH) to carry the forward. Omit this block (or
  // set enabled=false) to keep the previous behavior. See the README.
  // "tunnel": {
  //   "enabled": true,
  //   "host": "dev-box.example.com",       // dev box to dial (required)
  //   "port": 22,                          // ssh port (default 22)
  //   "user": "me",                        // ssh user (default: current OS user)
  //   "identityFile": "~/.ssh/id_ed25519", // preferred; else ssh-agent
  //   "knownHostsFile": "~/.ssh/known_hosts", // host-key verification
  //   "remoteBind": "127.0.0.1",           // bind on the dev box (loopback)
  //   "remotePort": 39788,                 // reverse listen port (default = port)
  //   "keepAliveSec": 30                   // ssh keepalive interval
  // },

  // Config-driven IDE opening. "cursor" and "vscode" ship out of the box; add
  // or override entries here. {uri} in launchArgs is the resolved folder URI,
  // built from remoteUri when a host is present, else localUri.
  "profiles": {
    "cursor": {
      "process": "Cursor",
      "exe": "", // "" = per-OS auto-detection
      "launchArgs": ["--new-window", "--folder-uri", "{uri}"],
      "localUri": "file://{path}",
      "remoteUri": "vscode-remote://ssh-remote+{host}{path}"
    },
    "vscode": {
      "process": "Code",
      "exe": "",
      "launchArgs": ["--new-window", "--folder-uri", "{uri}"],
      "localUri": "file://{path}",
      "remoteUri": "vscode-remote://ssh-remote+{host}{path}"
    }
  }
}
